# Copy this file to .env for local dev, and set the same values as
# environment variables in Railway (or wherever you deploy) for production.

# --- Database ---
# Railway's MySQL plugin gives you this connection string directly.
DATABASE_URL="mysql://user:password@host:port/database"

# --- Server ---
PORT=4000
# Comma-separated list of sites allowed to call this API. Use "*" while
# testing locally, then lock it down once your frontend has a real URL.
ALLOWED_ORIGINS="http://localhost:5500,https://your-greentrack-site.vercel.app"

# --- WhatsApp Cloud API (developers.facebook.com) ---
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TO_NUMBER=""          # your number, international format e.g. 2547XXXXXXXX

# --- GitHub webhook ---
# Any random string — set the SAME value in the repo's Webhook settings.
GITHUB_WEBHOOK_SECRET=""

# --- Notion integration (notion.so/my-integrations) ---
NOTION_TOKEN=""
NOTION_DATABASE_ID=""
NOTION_TITLE_PROPERTY="Name"   # change if your database's title column has a different name
